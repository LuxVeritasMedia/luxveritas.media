{
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "README.md",
      "AGENTS.md",
      "TODO.md",
      "apphosting.yaml",
      ".git/**",
      ".github/**",
      ".firebase/**",
      ".codex/**",
      ".agents/**",
      ".DS_Store",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "breadington-mvp/**",
      "buddington-mvp/**",
      "lowkey-hungry-mvp/**",
      "omelette-tv-guide/**",
      "mic-proof.html",
      "assets/qa-*.png",
      "tools/**",
      "docs/**",
      "*.md",
      "source_docs/**",
      "source_docs_round2/**",
      "brief_extracts/**",
      "brief_extracts_round2/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=(), payment=()"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=31536000"
          }
        ]
      },
      {
        "source": "**/*.@(png|jpg|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "**/*.@(svg|wav|webm)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=300"
          }
        ]
      },
      {
        "source": "/service-worker.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/submit",
        "function": {
          "functionId": "submitForm",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/event",
        "function": {
          "functionId": "trackSiteEvent",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/report",
        "function": {
          "functionId": "reportActivity",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
