{
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "README.md",
      "AGENTS.md",
      "TODO.md",
      "apphosting.yaml",
      ".git/**",
      ".github/**",
      ".firebase/**",
      ".codex/**",
      ".agents/**",
      ".DS_Store",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "breadington-mvp/**",
      "buddington-mvp/**",
      "lowkey-hungry-mvp/**",
      "omelette-tv-guide/**",
      "mic-proof.html",
      "assets/qa-*.png",
      "tools/**",
      "docs/**",
      "*.md",
      "source_docs/**",
      "source_docs_round2/**",
      "brief_extracts/**",
      "brief_extracts_round2/**"
    ],
    "headers": [
      {
        "source": "**/*.@(png|jpg|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=300"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/submit",
        "function": {
          "functionId": "submitForm",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/event",
        "function": {
          "functionId": "trackSiteEvent",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/report",
        "function": {
          "functionId": "reportActivity",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
