{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "README.md",
      "AGENTS.md",
      "TODO.md",
      "apphosting.yaml",
      "**/.*",
      "**/node_modules/**",
      "assets/qa-*.png",
      "tools/**",
      "docs/**",
      "*.md",
      "source_docs/**",
      "source_docs_round2/**",
      "brief_extracts/**"
      ,
      "brief_extracts_round2/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|png|jpg|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
