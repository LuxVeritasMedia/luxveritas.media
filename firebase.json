{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "README.md",
      "AGENTS.md",
      "TODO.md",
      "apphosting.yaml",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "assets/qa-*.png",
      "tools/**",
      "docs/**",
      "*.md",
      "source_docs/**",
      "source_docs_round2/**",
      "brief_extracts/**"
      ,
      "brief_extracts_round2/**"
    ],
    "headers": [
      {
        "source": "**/*.@(png|jpg|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=300"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/submit",
        "function": {
          "functionId": "submitForm",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
