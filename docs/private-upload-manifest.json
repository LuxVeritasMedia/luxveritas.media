{
  "schemaVersion": "luxveritas.private_upload_manifest.v1",
  "version": "2026-06-30-private-upload-manifest",
  "openApprovalId": "seed_binder_private_upload",
  "uploadStatus": "operator_review_required",
  "recommendedFolderName": "Lux Veritas Website Build",
  "shareTarget": "private_drive_or_private_repo",
  "purpose": "No-secret manifest for uploading the Lux Veritas website build package to a private collaborator folder without source zips, local caches, secrets, or internal ecosystem seed materials.",
  "approvalBoundary": "This manifest proves the upload package is curated and secret-free. It does not prove the private Drive or private repository upload happened; an internal operations owner must review and complete that external action.",
  "requiredPaths": [
    "AGENTS.md",
    "TODO.md",
    "app.js",
    "styles.css",
    "firebase.json",
    "apphosting.yaml",
    ".env.example",
    "robots.txt",
    "sitemap.xml",
    "site.webmanifest",
    "data/",
    "functions/",
    "assets/",
    "auth/",
    "portal/",
    "works/",
    "brands/",
    "legal/",
    "events/",
    "docs/arie-handoff-website-build.md",
    "docs/arie-quickstart.md",
    "docs/upload-checklist.md",
    "docs/private-upload-manifest.json",
    "docs/strategy-round2.md",
    "docs/deployment.md",
    "docs/supabase-blueprint.md",
    "docs/private-integration-profiles.json",
    "docs/private-integration-field-map.json",
    "docs/private-workflow-matrix.json",
    "docs/private-workflow-selection.json",
    "tools/build-static.mjs",
    "tools/serve-preview.mjs",
    "tools/qa-private-upload-manifest.mjs",
    "tools/qa-preview-helper.mjs"
  ],
  "optionalGeneratedPaths": [
    "index.html",
    "music.html",
    "film.html",
    "events.html",
    "codex.html",
    "about.html",
    "join.html",
    "contact.html",
    "press.html",
    "submissions.html",
    "ledger.html",
    "store.html",
    "membership.html",
    "investor.html",
    "community.html",
    "insights.html",
    "spmvp.html"
  ],
  "excludedPaths": [
    "source_docs/",
    "source_docs_round2/",
    "brief_extracts/",
    "brief_extracts_round2/",
    "*.zip",
    ".git/",
    ".DS_Store",
    "node_modules/",
    ".env",
    "docs/lux-ecosystem-master-seed.md",
    "docs/kys-binder-index.md",
    "docs/kys-*.md",
    "internal LuxFlow OS app folders"
  ],
  "secretExclusions": [
    "real .env files",
    "webhook URLs",
    "API keys",
    "Firebase private credentials",
    "Supabase service-role keys",
    "Stripe secrets",
    "Printify tokens"
  ],
  "firstOpenOrder": [
    "docs/arie-quickstart.md",
    "docs/arie-handoff-website-build.md",
    "AGENTS.md",
    "tools/build-static.mjs",
    "tools/serve-preview.mjs",
    "TODO.md"
  ],
  "verificationCommands": [
    "node tools/qa-private-upload-manifest.mjs",
    "node tools/qa-product-boundary.mjs",
    "node tools/qa-preview-helper.mjs",
    "node tools/qa-public-site.mjs"
  ],
  "postUploadOperatorChecks": [
    "Confirm the private folder exists and is access-controlled.",
    "Confirm Arie can access the folder.",
    "Confirm excluded internal seed/binder docs are not in the shared website-build folder unless deliberately shared in a separate private context.",
    "Confirm no secrets, source zips, local caches, or internal LuxFlow OS app folders are present.",
    "Run the verification commands from a clean local copy before continuing site work."
  ]
}
